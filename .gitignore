# Generated submissions. Keep only the human-facing writeup.
submission/*.zip
submission/*/
!submission/README.md

# Keep experiment tables and small text manifests tracked by default.
!experiments/
!experiments/*.csv
!experiments/*.txt
!experiments/README.md
!*.md

# Re-ignore rebuildable experiment caches and ranking dumps.
experiments/*_rank_*.csv
experiments/*_top1024*.txt
experiments/*_top140*.txt
experiments/*_top320*.txt
experiments/router_analysis_*/
experiments/router_metrics_*/
experiments/lr_cluster_names_*/
